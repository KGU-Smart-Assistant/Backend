## API keys
# Keep real secrets in local .env files only.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GEMINI_MODEL=gemini-3-flash-preview
KAKAO_MAP_API_KEY=
TRANSLATION_API_KEY=
TRANSLATION_PROVIDER=google

## PostgreSQL (docker-compose: service `db`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kgusmart

## SQLAlchemy DB URL
# Use host `db` when running inside Docker Compose.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/kgusmart

# Use host `localhost` when running python scripts/db_setup.py on a local PC.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/kgusmart
